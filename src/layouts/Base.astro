---
/**
 * Base layout — the HTML shell every page uses.
 * Loads global styles + brand fonts, sets meta, then renders the page
 * via <slot />. Fonts are placeholders (Oswald + Inter) until Dave's
 * design system defines the real ones in tokens.css.
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CROP',
  description = 'CROP — coming soon.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Brand fonts (placeholder — swap when Dave defines the system) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;800;900&family=Oswald:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
