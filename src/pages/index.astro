---
/**
 * Home page, CROP v2 (structure pass).
 *
 * Goals for this pass: light theme, lead with brands and work for instant
 * credibility, keep copy cool and brief, sell the benefit not the service,
 * and frame Carl + Dave as two senior partners (no juniors, no faff). The
 * "Crop" name idea is demoted to a short About line. Network gets one
 * understated mention, not a headline.
 *
 * Copy here is placeholder, to be polished by Carl. Photos are placeholder
 * squares. All styling references tokens.css so the brand re-themes from
 * one file when Dave's Figma system lands.
 *
 * House rules: no em-dashes, British spelling, no emoji.
 */
import Base from '../layouts/Base.astro';

// Brands strip, shown at a glance under the hero (real names from past work).
const brands = [
  'Guinness', 'The Guardian', 'lastminute.com', 'OpenTable', 'Hailo', 'Uber',
  'Trainline', 'Tide', 'Modulr', 'Sage', 'Specsavers', 'Peugeot', 'NHS',
  'HSBC', 'TUI', 'Standard Chartered', 'Ravelin', 'Hiscox',
];

// Work tiles. Placeholder media squares; captions are client + discipline.
const work = [
  { client: 'lastminute.com', tag: 'Brand & marketing' },
  { client: 'Specsavers', tag: 'Identity & design' },
  { client: 'Guinness', tag: 'Brand marketing' },
  { client: 'Sage', tag: 'Brand & design' },
  { client: 'Hailo', tag: 'Brand & growth' },
  { client: 'Peugeot', tag: 'Design' },
  { client: 'OpenTable', tag: 'Brand & marketing' },
  { client: 'Ravelin', tag: 'Identity & design' },
];

const people = [
  {
    role: 'Strategy & story',
    name: 'Carl Mesner Lyons',
    body: 'Twenty years running marketing for household-name brands and launching startups into the mainstream. The organising idea, and the story a whole business can build on.',
    clients: 'Guinness, The Guardian, lastminute.com, OpenTable, Hailo, CarWow, Trainline, Uber, Tide, Modulr.',
  },
  {
    role: 'Design & identity',
    name: 'Dave Forsyth',
    body: 'Over twenty years of agency-grade brand and design for some of the biggest names around. The visual world that makes the idea unmistakable.',
    clients: 'Sage, Specsavers, Peugeot, NHS, HSBC, TUI, NFU Mutual, Standard Chartered, Ravelin, Hiscox.',
  },
];

const quotes = [
  { q: 'Carl is one of the few people I can imagine working with to turn the idea of lastminute.com’s brand that lived in my and Brent’s head and make it a reality.', by: 'Martha Lane Fox, Co-founder, lastminute.com' },
  { q: 'Without doubt he is the best I have worked with. Fast, creative, precise, current, purposeful, demanding, flexible.', by: 'Gerry Carr, Marketing Director, Ravelin' },
  { q: 'Carl is one of the most gifted marketeers I have ever worked with. He combines creative vision with the solid common sense required to deliver a successful brand and product.', by: 'Nicky Drake, Senior Director of Product, Meta' },
  { q: 'Dave consistently delivers high quality work while keeping us on brand, always quick to respond and turn work around. It is always a pleasure working with Dave.', by: 'Grace Reeves, Project Manager, Jetstack' },
];

const email = 'hello@wearecrop.co.uk';
---

<Base
  title="Crop, a branding studio"
  description="Crop is a branding studio. Two senior partners, sharp strategy and design, and decades of brands behind us."
>
  <!-- Top bar -->
  <header class="bar">
    <div class="bar__inner">
      <a class="brand" href="#top">
        <span class="brand__mark">CROP</span>
        <span class="brand__strap">Unapologetic branding</span>
      </a>
      <nav class="nav">
        <a href="#work">Work</a>
        <a href="#studio">Studio</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <!-- Hero -->
    <section class="hero">
      <div class="inner">
        <p class="eyebrow">Brand strategy and identity</p>
        <h1 class="hero__title">Find the brand. Lose the rest.</h1>
        <p class="hero__sub">Lean, powerful brand stories. Distinctive, memorable identities. Two senior partners with decades of brands behind us, modern tools, and none of the agency faff.</p>
        <div class="cta-row">
          <a class="btn btn--primary" href="#contact">Start a conversation</a>
          <a class="btn btn--ghost" href="#work">See the work</a>
        </div>
      </div>
    </section>

    <!-- Brands strip: credibility at a glance -->
    <section class="strip">
      <div class="inner">
        <p class="strip__label">Brands we have shaped</p>
        <ul class="strip__list">
          {brands.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </section>

    <!-- What we do: brief, two disciplines -->
    <section class="block">
      <div class="inner">
        <div class="duo">
          <article class="duo__item">
            <p class="duo__no">01</p>
            <h2 class="duo__title">Brand strategy</h2>
            <p class="muted">A lean, powerful brand story. The one true thing you are about, made the idea everything else hangs on.</p>
          </article>
          <article class="duo__item">
            <p class="duo__no">02</p>
            <h2 class="duo__title">Brand identity</h2>
            <p class="muted">A distinctive, memorable visual identity. A look and a voice no one can mistake for anyone else.</p>
          </article>
        </div>
        <div class="extend">
          <h3 class="extend__title">A senior studio with a serious network.</h3>
          <p class="muted">No studio rent, no London overheads, no juniors on your budget. You pay for the work, not the fluff. When a brief needs more, photography, film, web, PR, we build the right team from a hand-picked network we trust, the cream of the crop, and run it for you.</p>
        </div>
      </div>
    </section>

    <!-- Work: the centrepiece -->
    <section id="work" class="block">
      <div class="inner">
        <p class="eyebrow">Work</p>
        <h2 class="title">Big-league experience. Small-studio focus.</h2>
        <div class="work-grid">
          {work.map((w) => (
            <figure class="work">
              <div class="work__media"><span>Image</span></div>
              <figcaption class="work__cap">
                <span class="work__client">{w.client}</span>
                <span class="work__tag">{w.tag}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Studio: the two of us, with photo placeholders -->
    <section id="studio" class="block">
      <div class="inner">
        <p class="eyebrow">The studio</p>
        <h2 class="title">You hire us. You get us.</h2>
        <p class="lead">Two senior people, on the tools from first call to last. The people who pitch the work are the people who do it.</p>
        <div class="people">
          {people.map((p) => (
            <article class="person">
              <div class="person__photo"><span>Photo</span></div>
              <div class="person__text">
                <p class="person__role">{p.role}</p>
                <h3 class="person__name">{p.name}</h3>
                <p class="muted">{p.body}</p>
                <p class="person__clients"><strong>Selected clients:</strong> {p.clients}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Proof -->
    <section class="block">
      <div class="inner">
        <p class="eyebrow">In their words</p>
        <div class="quotes">
          {quotes.map((qt) => (
            <figure class="quote">
              <blockquote>&ldquo;{qt.q}&rdquo;</blockquote>
              <figcaption>{qt.by}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- About: the name, demoted and brief -->
    <section id="about" class="block">
      <div class="inner">
        <p class="eyebrow">About us</p>
        <div class="beliefs">
          <div class="belief">
            <h2 class="belief__head">Strategy is what you don't do.</h2>
            <p class="muted">Most brands reach for more. More messages, more audiences, more things they could be, until the edges blur and nothing sticks. The harder, better move is to pick the one thing you can genuinely own, make it matter to the people you want, and let the rest go.</p>
          </div>
          <div class="belief">
            <h2 class="belief__head">Design is finished when there's nothing left to take away.</h2>
            <p class="muted">Identity is reduction. We keep cutting, in the words and in the visuals, until only what is essential and true is left. It is where our name comes from, and it is how we work on everything.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="contact">
      <div class="inner">
        <h2 class="contact__title">Get a brand as good as your product.</h2>
        <p class="lead lead--center">One your customers want in their life. One your team believe in. One that supercharges your business.</p>
        <a class="btn btn--primary" href={`mailto:${email}`}>{email}</a>
      </div>
    </section>
  </main>

  <footer class="foot">
    <div class="foot__inner">
      <span><strong>CROP</strong> &middot; A branding studio</span>
      <a href={`mailto:${email}`}>{email}</a>
    </div>
  </footer>
</Base>

<style>
  /* Layout helpers */
  .inner { max-width: var(--content-max); margin: 0 auto; padding: 0 var(--space-4); }
  .inner.narrow { max-width: 760px; }
  .block { padding: var(--space-6) 0; border-bottom: 1px solid var(--color-line); }

  .eyebrow {
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }
  .title { font-size: var(--text-title); letter-spacing: var(--tracking-tight); max-width: 22ch; }
  .lead { font-size: var(--text-lead); color: var(--color-muted); max-width: 62ch; margin-top: var(--space-3); }
  .muted { color: var(--color-muted); margin-top: var(--space-2); }

  /* Top bar */
  .bar {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }
  .bar__inner {
    max-width: var(--content-max); margin: 0 auto;
    padding: 0 var(--space-4); height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .brand { display: inline-flex; flex-direction: column; line-height: 1; }
  .brand:hover { text-decoration: none; }
  .brand__mark { font-family: var(--font-heading); font-weight: 700; font-size: 1.4rem; letter-spacing: 0.06em; color: var(--color-fg); }
  .brand__strap { font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-muted); margin-top: 4px; }
  .nav { display: flex; gap: var(--space-4); }
  .nav a { color: var(--color-muted); font-size: var(--text-base); }
  .nav a:hover { color: var(--color-fg); text-decoration: none; }
  @media (max-width: 720px) { .nav { gap: var(--space-3); } }

  /* Hero */
  .hero { padding: var(--space-6) 0 var(--space-5); }
  .hero__title { font-size: var(--text-lg); letter-spacing: var(--tracking-tight); max-width: 14ch; }
  .hero__sub { font-size: var(--text-lead); color: var(--color-muted); max-width: 48ch; margin-top: var(--space-4); }
  .cta-row { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-5); }

  /* Buttons */
  .btn {
    display: inline-block; font-family: var(--font-heading);
    font-weight: 700; font-size: var(--text-base);
    padding: 0.8em 1.6em; border-radius: var(--radius);
    border: 1px solid var(--color-fg);
  }
  .btn:hover { text-decoration: none; }
  .btn--primary { background: var(--color-fg); color: var(--color-bg); }
  .btn--ghost { background: transparent; color: var(--color-fg); }

  /* Brands strip */
  .strip { padding: var(--space-5) 0; border-top: 1px solid var(--color-line); border-bottom: 1px solid var(--color-line); background: var(--color-surface); }
  .strip__label { font-size: var(--text-small); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-muted); margin-bottom: var(--space-3); }
  .strip__list { list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-4); }
  .strip__list li { font-family: var(--font-heading); font-weight: 500; font-size: 1.2rem; color: var(--color-fg); opacity: 0.85; }

  /* What we do (two disciplines) */
  .duo { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  .duo__no { font-family: var(--font-heading); color: var(--color-brand); font-size: var(--text-small); }
  .duo__title { font-size: var(--text-title); letter-spacing: var(--tracking-tight); margin: var(--space-2) 0; }
  .extend { margin-top: var(--space-5); padding-top: var(--space-4); border-top: 1px solid var(--color-line); max-width: 66ch; }
  .extend__title { font-family: var(--font-heading); font-size: 1.6rem; letter-spacing: var(--tracking-tight); }
  .extend .muted { margin-top: var(--space-3); }

  /* Beliefs (less is more) */
  .beliefs { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  .belief__head { font-family: var(--font-heading); font-size: clamp(1.4rem, 2.6vw, 2rem); letter-spacing: var(--tracking-tight); line-height: 1.1; max-width: 20ch; }
  .belief .muted { margin-top: var(--space-3); }
  @media (max-width: 720px) { .beliefs { grid-template-columns: 1fr; gap: var(--space-4); } }

  /* Work tile hover (signals it will be clickable) */
  .work__media { transition: border-color 0.15s ease; }
  .work:hover .work__media { border-color: var(--color-muted); }

  /* Contact supporting line */
  .contact .lead { text-align: center; max-width: 44ch; }
  @media (max-width: 720px) { .duo { grid-template-columns: 1fr; gap: var(--space-4); } }

  /* Work grid */
  .work-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3); margin-top: var(--space-5); }
  .work { margin: 0; }
  .work__media {
    aspect-ratio: 4 / 3; border: 1px solid var(--color-line); border-radius: var(--radius);
    background: var(--color-surface);
    display: flex; align-items: center; justify-content: center;
  }
  .work__media span { font-size: var(--text-small); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-muted); opacity: 0.6; }
  .work__cap { display: flex; flex-direction: column; gap: 2px; margin-top: var(--space-2); }
  .work__client { font-family: var(--font-heading); font-weight: 500; font-size: 1.05rem; color: var(--color-fg); }
  .work__tag { font-size: var(--text-small); color: var(--color-muted); }
  @media (max-width: 900px) { .work-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .work-grid { grid-template-columns: 1fr; } }

  /* Studio people */
  .people { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-top: var(--space-5); }
  .person { display: flex; gap: var(--space-4); }
  .person__photo {
    flex: 0 0 132px; width: 132px; height: 132px;
    border: 1px solid var(--color-line); border-radius: var(--radius);
    background: var(--color-surface);
    display: flex; align-items: center; justify-content: center;
  }
  .person__photo span { font-size: var(--text-small); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-muted); opacity: 0.6; }
  .person__role { font-size: var(--text-small); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-brand); }
  .person__name { font-size: 1.5rem; margin: 4px 0 var(--space-2); }
  .person__clients { margin-top: var(--space-3); font-size: var(--text-base); color: var(--color-muted); }
  .person__clients strong { color: var(--color-fg); }
  @media (max-width: 820px) { .people { grid-template-columns: 1fr; } }
  @media (max-width: 420px) { .person { flex-direction: column; } }

  /* Proof quotes */
  .quotes { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-top: var(--space-4); }
  .quote { background: var(--color-surface); border: 1px solid var(--color-line); border-radius: var(--radius); padding: var(--space-4); margin: 0; }
  .quote blockquote { margin: 0; font-size: 1.05rem; }
  .quote figcaption { margin-top: var(--space-3); font-size: var(--text-base); color: var(--color-muted); }
  @media (max-width: 720px) { .quotes { grid-template-columns: 1fr; } }

  /* Contact */
  .contact { padding: var(--space-6) 0; text-align: center; }
  .contact .inner { display: flex; flex-direction: column; align-items: center; }
  .contact__title { font-size: var(--text-lg); letter-spacing: var(--tracking-tight); }
  .contact .btn { margin-top: var(--space-4); }

  /* Footer */
  .foot { border-top: 1px solid var(--color-line); }
  .foot__inner {
    max-width: var(--content-max); margin: 0 auto; padding: var(--space-4);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: var(--space-2);
    font-size: var(--text-base); color: var(--color-muted);
  }
  .foot__inner strong { color: var(--color-fg); font-family: var(--font-heading); }
  .foot__inner a { color: var(--color-muted); }
</style>
