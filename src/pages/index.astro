---
/**
 * Home page, CROP v1.
 *
 * This is the first real content build, replacing the holding page.
 * It is deliberately plain: structure and copy in the right order so
 * we can push to staging and react to it. All styling references
 * tokens.css, so when Dave's Figma design system lands the whole page
 * re-themes from there. Keep the section ids so future nav/links hold.
 *
 * House rules in the copy: no em-dashes, British spelling, no emoji.
 */
import Base from '../layouts/Base.astro';

const services = [
  {
    num: '01',
    title: 'Brand strategy',
    body: 'The thinking. We get to the single organising idea that makes sense of your whole business, then turn it into a story everyone can build behind, inside and out.',
  },
  {
    num: '02',
    title: 'Brand identity',
    body: 'The craft. We give the idea a face: a visual world, a voice and a system that works everywhere, from the logo to the last touchpoint.',
  },
  {
    num: '03',
    title: 'Whatever it needs next',
    body: 'The reach. Website build, PR, performance, film, packaging. We bring in trusted specialists from our network and run it, so the brand arrives fully formed.',
  },
];

const steps = [
  { name: 'Discover', body: 'We immerse ourselves in your business, your market and your people. We read everything that matters and run a focused workshop to surface the raw material.' },
  { name: 'Crop', body: 'We distil it. We find the organising idea and the brand on a page, the why, what and how, then sharpen it until it is undeniable.' },
  { name: 'Build', body: 'We bring it to life. Identity, voice and creative starters, made into a system you can actually run. We can keep going with the network from there.' },
];

const people = [
  {
    role: 'Strategy',
    name: 'Carl Mesner Lyons',
    body: 'Twenty years client-side, running marketing for major brands and turning startups into household names. Carl takes something complicated and makes it simple: the brand story a whole business can build from.',
    clients: 'Guinness, The Guardian, lastminute.com, OpenTable, Hailo, CarWow, Trainline, Uber, Tide, Modulr.',
  },
  {
    role: 'Design',
    name: 'Dave Forsyth',
    body: 'Over twenty years as a brand and multimedia designer for clients large and small, local and international. Agency-standard craft with a freelancer’s flexibility, noted for sharp ideas, contemporary style and solid design.',
    clients: 'Sage, Specsavers, Peugeot, NHS, HSBC, TUI, NFU Mutual, Standard Chartered, Ravelin, Hiscox.',
  },
];

const quotes = [
  { q: 'Carl is one of the few people I can imagine working with to turn the idea of lastminute.com’s brand that lived in my and Brent’s head and make it a reality.', by: 'Martha Lane Fox, Co-founder, lastminute.com' },
  { q: 'Without doubt he is the best I have worked with. Fast, creative, precise, current, purposeful, demanding, flexible. If you want something done well, on budget and to a truly high standard, then try Dave.', by: 'Gerry Carr, Marketing Director, Ravelin' },
  { q: 'Carl is one of the most gifted marketeers I have ever worked with. He combines creative vision with the solid common sense required to deliver a successful brand and product.', by: 'Nicky Drake, Senior Director of Product, Meta' },
  { q: 'Dave is curious about what makes the buyer tick. He will bring perspective to what you are trying to achieve, then make it look great, and help you achieve it.', by: 'Grainne Shaughnessy, Marketing Manager, Brightpearl' },
];

const clientList = 'Guinness, The Guardian, lastminute.com, OpenTable, Hailo, Sage, Specsavers, Peugeot, NHS, HSBC, TUI, Trainline, Uber, Tide, Modulr, Ravelin, Standard Chartered, NFU Mutual';

// Placeholder email until the real address is live.
const email = 'hello@wearecrop.co.uk';
---

<Base
  title="Crop, a branding studio"
  description="Crop is a branding studio. We get brands down to their essence: the story that is true and the identity that makes it land."
>
  <!-- Top bar -->
  <header class="bar">
    <div class="bar__inner">
      <a class="brand" href="#top">CROP</a>
      <nav class="nav">
        <a href="#services">What we do</a>
        <a href="#name">The name</a>
        <a href="#approach">Approach</a>
        <a href="#studio">Studio</a>
        <a href="#proof">Work</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <!-- Hero -->
    <section class="hero">
      <div class="inner">
        <p class="eyebrow">Branding studio</p>
        <h1 class="hero__title">We get brands down to what matters.</h1>
        <p class="hero__sub">Crop is a branding studio. We find the truth at the core of your brand, then build the story and the identity that make it land.</p>
        <div class="cta-row">
          <a class="btn btn--primary" href="#contact">Start a conversation</a>
          <a class="btn btn--ghost" href="#services">See what we do</a>
        </div>
      </div>
    </section>

    <!-- What we do -->
    <section id="services" class="block">
      <div class="inner">
        <p class="eyebrow">What we do</p>
        <h2 class="title">Two things we do brilliantly, and a network for everything after.</h2>
        <p class="lead">Most brand problems are really two problems wearing one coat. Work out what you stand for, then make people feel it. We do both, under one roof.</p>
        <div class="cards">
          {services.map((s) => (
            <article class="card">
              <p class="card__num">{s.num}</p>
              <h3 class="card__title">{s.title}</h3>
              <p class="card__body">{s.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- The name -->
    <section id="name" class="block">
      <div class="inner">
        <p class="eyebrow">Why Crop</p>
        <h2 class="title">A name that means the same thing twice.</h2>
        <div class="split">
          <div>
            <h3 class="sub-h">The design read</h3>
            <p class="pullquote">&ldquo;You know you have finished not when there is nothing left to add, but when there is nothing left to take away.&rdquo;</p>
            <p class="muted">Crop is a designer’s tool. Great identity is the result of taking away until only the essential remains.</p>
          </div>
          <div>
            <h3 class="sub-h">The strategy read</h3>
            <p class="muted">A brand is strongest when it is reduced to its truth. We crop away the noise, the hedging and the inherited language until what is left is the one idea worth building on. Same instinct, both halves of the job.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Approach -->
    <section id="approach" class="block">
      <div class="inner">
        <p class="eyebrow">How we work</p>
        <h2 class="title">Simple, fast and built to be used, not just launched.</h2>
        <p class="lead">It starts with questions. A lot of them. That is how we find out what makes you tick and where the real opportunity sits.</p>
        <div class="steps">
          {steps.map((st) => (
            <div class="step">
              <p class="step__name">{st.name}</p>
              <p class="muted">{st.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Studio -->
    <section id="studio" class="block">
      <div class="inner">
        <p class="eyebrow">The studio</p>
        <h2 class="title">Two senior partners, forty years between them, no agency overheads.</h2>
        <p class="lead">You work directly with the people doing the work. One leads the strategy, one leads the design, and the join between them is the point.</p>
        <div class="people">
          {people.map((p) => (
            <article class="person">
              <p class="person__role">{p.role}</p>
              <h3 class="person__name">{p.name}</h3>
              <p class="muted">{p.body}</p>
              <p class="person__clients"><strong>Selected clients:</strong> {p.clients}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Proof -->
    <section id="proof" class="block">
      <div class="inner">
        <p class="eyebrow">Proof</p>
        <h2 class="title">People who have trusted us with their brand.</h2>
        <p class="clients"><strong>Between us:</strong> {clientList}</p>
        <div class="quotes">
          {quotes.map((qt) => (
            <figure class="quote">
              <blockquote>&ldquo;{qt.q}&rdquo;</blockquote>
              <figcaption>{qt.by}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="contact">
      <div class="inner">
        <h2 class="contact__title">Let us find the truth in your brand.</h2>
        <p class="lead lead--center">Tell us what you are wrestling with. We will tell you, honestly, whether we can help and how we would start.</p>
        <a class="btn btn--primary" href={`mailto:${email}`}>{email}</a>
      </div>
    </section>
  </main>

  <footer class="foot">
    <div class="foot__inner">
      <span><strong>CROP</strong> &middot; A branding studio</span>
      <a href={`mailto:${email}`}>{email}</a>
    </div>
  </footer>
</Base>

<style>
  /* Layout helpers */
  .inner { max-width: var(--content-max); margin: 0 auto; padding: 0 var(--space-4); }
  .block { padding: var(--space-6) 0; border-bottom: 1px solid var(--color-line); }

  .eyebrow {
    font-size: var(--text-small);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }
  .title { font-size: var(--text-title); letter-spacing: var(--tracking-tight); max-width: 22ch; }
  .sub-h { font-size: var(--text-small); margin-bottom: var(--space-2); }
  .lead { font-size: var(--text-lead); color: var(--color-muted); max-width: 60ch; margin-top: var(--space-3); }
  .lead--center { margin-left: auto; margin-right: auto; }
  .muted { color: var(--color-muted); margin-top: var(--space-2); }

  /* Top bar */
  .bar {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }
  .bar__inner {
    max-width: var(--content-max); margin: 0 auto;
    padding: 0 var(--space-4); height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .brand { font-family: var(--font-heading); font-weight: 700; font-size: 1.4rem; letter-spacing: 0.04em; color: var(--color-fg); }
  .brand:hover { text-decoration: none; }
  .nav { display: flex; gap: var(--space-4); }
  .nav a { color: var(--color-muted); font-size: var(--text-base); }
  .nav a:hover { color: var(--color-fg); text-decoration: none; }
  @media (max-width: 820px) { .nav { display: none; } }

  /* Hero */
  .hero { padding: var(--space-6) 0; border-bottom: 1px solid var(--color-line); }
  .hero__title { font-size: var(--text-lg); letter-spacing: var(--tracking-tight); max-width: 16ch; }
  .hero__sub { font-size: var(--text-lead); color: var(--color-muted); max-width: 44ch; margin-top: var(--space-4); }

  /* Buttons */
  .cta-row { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-5); }
  .btn {
    display: inline-block; font-family: var(--font-heading);
    font-weight: 700; font-size: var(--text-base);
    padding: 0.85em 1.6em; border-radius: var(--radius);
    border: 1px solid var(--color-fg);
  }
  .btn:hover { text-decoration: none; }
  .btn--primary { background: var(--color-brand); color: var(--color-on-brand); border-color: var(--color-brand); }
  .btn--ghost { background: transparent; color: var(--color-fg); }

  /* Cards (services) */
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); margin-top: var(--space-5); }
  .card { background: var(--color-surface); border: 1px solid var(--color-line); border-radius: var(--radius); padding: var(--space-4); }
  .card__num { font-family: var(--font-heading); color: var(--color-brand); font-size: var(--text-small); }
  .card__title { font-size: 1.4rem; margin: var(--space-2) 0; }
  .card__body { color: var(--color-muted); }
  @media (max-width: 820px) { .cards { grid-template-columns: 1fr; } }

  /* The name split */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); margin-top: var(--space-4); }
  .pullquote { font-size: var(--text-lead); line-height: 1.35; max-width: 26ch; }
  @media (max-width: 820px) { .split { grid-template-columns: 1fr; gap: var(--space-4); } }

  /* Approach steps */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-top: var(--space-5); }
  .step { border-top: 2px solid var(--color-fg); padding-top: var(--space-3); }
  .step__name { font-family: var(--font-heading); font-size: 1.25rem; }
  @media (max-width: 820px) { .steps { grid-template-columns: 1fr; } }

  /* Studio people */
  .people { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-top: var(--space-5); }
  .person { background: var(--color-surface); border: 1px solid var(--color-line); border-radius: var(--radius); padding: var(--space-4); }
  .person__role { font-size: var(--text-small); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--color-brand); }
  .person__name { font-size: 1.5rem; margin: var(--space-2) 0; }
  .person__clients { margin-top: var(--space-3); font-size: var(--text-base); color: var(--color-muted); }
  .person__clients strong { color: var(--color-fg); }
  @media (max-width: 820px) { .people { grid-template-columns: 1fr; } }

  /* Proof */
  .clients { margin-top: var(--space-3); color: var(--color-muted); line-height: 2; }
  .clients strong { color: var(--color-fg); }
  .quotes { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-top: var(--space-5); }
  .quote { background: var(--color-surface); border: 1px solid var(--color-line); border-radius: var(--radius); padding: var(--space-4); margin: 0; }
  .quote blockquote { margin: 0; }
  .quote figcaption { margin-top: var(--space-3); font-size: var(--text-base); color: var(--color-muted); }
  @media (max-width: 820px) { .quotes { grid-template-columns: 1fr; } }

  /* Contact */
  .contact { padding: var(--space-6) 0; text-align: center; }
  .contact .inner { display: flex; flex-direction: column; align-items: center; }
  .contact__title { font-size: var(--text-lg); letter-spacing: var(--tracking-tight); }
  .contact .btn { margin-top: var(--space-4); }

  /* Footer */
  .foot { border-top: 1px solid var(--color-line); }
  .foot__inner {
    max-width: var(--content-max); margin: 0 auto; padding: var(--space-4);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: var(--space-2);
    font-size: var(--text-base); color: var(--color-muted);
  }
  .foot__inner strong { color: var(--color-fg); font-family: var(--font-heading); }
</style>
